{
  "family": "rag-ui-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::968909452879:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::968909452879:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "rag-ui",
      "image": "968909452879.dkr.ecr.eu-west-3.amazonaws.com/rag-ui:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8501,
          "hostPort": 8501
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/rag-ui",
          "awslogs-region": "eu-west-3",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}